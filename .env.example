# Copy this file to .env and adjust values as needed.
# No API keys required — all services run locally.

# Alert thresholds (fractions)
DRIFT_WARNING_THRESHOLD=0.15
DRIFT_CRITICAL_THRESHOLD=0.30
PERFORMANCE_DEGRADATION_THRESHOLD=0.10

# Hours without ground-truth labels before alerting
MISSING_LABELS_ALERT_HOURS=48

# Minimum labeled rows required to compute performance metrics
MIN_SAMPLES_FOR_METRICS=30

# Monitoring windows (days)
SHORT_WINDOW_DAYS=7
LONG_WINDOW_DAYS=30
